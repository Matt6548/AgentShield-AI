SAFECORE_ENV=local
SAFECORE_DRY_RUN=true
SAFECORE_API_HOST=0.0.0.0
SAFECORE_API_PORT=8000
SAFECORE_LOG_LEVEL=INFO
SAFECORE_AUDIT_FILE=/app/runtime/audit/audit.log.jsonl
SAFECORE_APPROVAL_ESCALATE_AFTER_SECONDS=300
SAFECORE_APPROVAL_EXPIRE_AFTER_SECONDS=900
SAFECORE_APPROVAL_ESCALATION_TARGET=security-oncall

